# ── Groq API Keys (multi-key support) ───────────────────────────────────────
# Add as many as you want — the app auto-detects every GROQ_API_KEY_* variable.
GROQ_API_KEY_1=gsk_xxxxxxxxxxxxxx
GROQ_API_KEY_2=gsk_xxxxxxxxxxxxxx
GROQ_API_KEY_3=gsk_xxxxxxxxxxxxxx
# GROQ_API_KEY_4=...
# GROQ_API_KEY_5=...

# Optional: override the model (defaults to llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile
# Optional: cheaper/faster model for memory extraction & summary (default below)
# GROQ_MEMORY_MODEL=llama-3.1-8b-instant
# Optional: cap reply length (tokens); default 2048
# GROQ_MAX_OUTPUT_TOKENS=2048
# Optional: chat creativity (0=deterministic, 1=creative); default 0.6
# GROQ_CHAT_TEMPERATURE=0.6
# Optional: timezone for time-awareness in the prompt; default Asia/Jakarta
# APP_TIMEZONE=Asia/Jakarta

# ── Upstash Redis ────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://xxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxx

# ── Upstash Vector (long-term semantic memory) ───────────────────────────────
# Create an index in the Upstash console with the BGE-M3 embedding model
# (multilingual). Leave unset to disable long-term memory.
UPSTASH_VECTOR_REST_URL=https://xxxxxx.upstash.io
UPSTASH_VECTOR_REST_TOKEN=xxxxxx

# ── Meta WhatsApp Cloud API ──────────────────────────────────────────────────
WA_PHONE_NUMBER_ID=xxxxxx
WA_ACCESS_TOKEN=xxxxxx
WA_APP_SECRET=xxxxxx
WEBHOOK_VERIFY_TOKEN=your_custom_verify_token_here

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Optional: override the agent's system prompt
# SYSTEM_PROMPT=Kamu adalah AI agent pribadi...
