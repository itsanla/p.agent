# Frontend is a static client — the ONLY config it needs is the Worker API URL.
# All secrets/logic live in the Hono Worker (apps/api). See apps/api/.dev.vars.

# Local dev: the Worker from `wrangler dev` (default port 8787).
NEXT_PUBLIC_API_URL=http://localhost:8787

# Production: your deployed Worker URL, e.g.
# NEXT_PUBLIC_API_URL=https://agent-api.<your-subdomain>.workers.dev
