{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "agent-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-29",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "agent",
      "database_id": "1aaf617c-b906-4cb0-846e-5b705ddb522a",
      "migrations_dir": "drizzle/migrations"
    }
  ],
  "vectorize": [
    {
      "binding": "VECTORIZE",
      "index_name": "linda-memory",
      "remote": true
    }
  ],
  "ai": {
    "binding": "AI",
    "remote": true
  },
  "triggers": {
    "crons": ["0 * * * *"]
  },
  "vars": {
    "APP_TIMEZONE": "Asia/Jakarta",
    "GROQ_CHAT_MODEL": "llama-3.3-70b-versatile",
    "GROQ_UTILITY_MODEL": "llama-3.1-8b-instant",
    // Models picked for their Groq TPM headroom (model.json): plan = 120B (small
    // request, best reasoning); synth = Scout (30k TPM, long context); write =
    // 70B (12k TPM, strong writer — 120B's 8k TPM is too low for a full manuscript).
    "GROQ_PLAN_MODEL": "openai/gpt-oss-120b",
    "GROQ_SYNTH_MODEL": "meta-llama/llama-4-scout-17b-16e-instruct",
    "GROQ_WRITE_MODEL": "llama-3.3-70b-versatile",
    "GROQ_CHECK_MODEL": "openai/gpt-oss-safeguard-20b",
    "SCHOLAR_MAILTO": "anlaharpanda@gmail.com",
    "TAVILY_MONTHLY_CREDITS": "1000"
  }
}
